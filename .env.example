# Get from Google AI Studio: aistudio.google.com
GEMINI_API_KEY=your_key_here

# Get from brightdata.com after redeeming promo code "unlocked"
BRIGHT_DATA_API_KEY=your_key_here

# Optional: only needed if routing Stage 3 synthesis through Claude
# Use your personal account API key
ANTHROPIC_API_KEY=your_key_here

# Path to SQLite database (default: realwork.db in project root)
DB_PATH=realwork.db

# Bright Data hard cap in USD
BRIGHT_DATA_BUDGET=250.0
